# Copy this file to ".env" and fill in your Supabase project values.
# Find them in Supabase dashboard -> Project Settings -> API.

# Flip to "true" once the schema + policies are applied and env is set.
VITE_USE_SUPABASE=false

VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR-ANON-PUBLIC-KEY

# Public app URL used by OAuth redirects once deployed.
# Local dev can stay http://localhost:5173.
VITE_SITE_URL=http://localhost:5173
